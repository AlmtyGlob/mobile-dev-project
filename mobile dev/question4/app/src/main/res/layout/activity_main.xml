<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Word Manipulator"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etWord1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter first word"
        android:inputType="text" />

    <EditText
        android:id="@+id/etWord2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter second word"
        android:inputType="text" />

    <EditText
        android:id="@+id/etWord3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter third word"
        android:inputType="text" />

    <Button
        android:id="@+id/btnManipulate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Manipulate" />

    <Button
        android:id="@+id/btnReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <TextView
        android:id="@+id/tvResultsDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:textSize="16sp"
        android:lineSpacingExtra="8dp"/>

</LinearLayout>